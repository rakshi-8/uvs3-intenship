<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App1.Homepage"
             Title="Homepage">
    <VerticalStackLayout
        Padding="30"
        Spacing="15">

        <Label 
            Text="Homepage"
            FontSize="25"
            HorizontalOptions="Center" />
        <Button
            Text="My Profile"
            Clicked="GoProfile"/>
        <Button
            Text="My Work"
            Clicked="GoWork"/>
        <Button
            Text="Messages"/>
        <Button
            Text="Setting"/>


    </VerticalStackLayout>
</ContentPage>