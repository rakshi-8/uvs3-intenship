    xmlns:local="clr-namespace:app3"
    xmlns:pages="clr-namespace:app3.pages"
    Title="app3">

    <FlyoutItem Title="Home page">
        <Tab Title="Pages">
         <ShellContent
        Title="Page1"
        ContentTemplate="{DataTemplate pages:Page1}"/>
            <ShellContent
     Title="Page2"
     ContentTemplate="{DataTemplate pages:Page2}"/>
        </Tab>
        <ShellContent
     Title="Page3"
     ContentTemplate="{DataTemplate pages:Page3}"/>
    </FlyoutItem>
    <ShellContent
   Title="Page4"
   ContentTemplate="{DataTemplate pages:Page4}"/>
    <ShellContent
Title="Page5"
ContentTemplate="{DataTemplate pages:Page5}"/>
   


</Shell>
